{
  "name": "engram-desktop-view",
  "version": "1.0.0",
  "description": "Desktop dashboard to monitor and explore Engram memory events",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "reinstall": "rm -rf node_modules dist src-tauri/target && pnpm install",
    "biome-all": "biome check --write .",
    "pre-commit": "biome check --write . && pnpm build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.1.1",
    "@tanstack/react-query": "^5.62.7",
    "zustand": "^5.0.2",
    "axios": "^1.7.9",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.3",
    "@tauri-apps/api": "^2.2.0",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.2",
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}
