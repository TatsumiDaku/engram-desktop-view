{
	"name": "engram-desktop-view",
	"version": "1.0.0",
	"description": "Desktop dashboard to monitor and explore Engram memory events",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build",
		"reinstall": "rm -rf node_modules dist src-tauri/target && pnpm install",
		"biome-all": "biome check --write .",
		"pre-commit": "biome check --write . && pnpm build"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.62.7",
		"axios": "^1.7.9",
		"clsx": "^2.1.1",
		"i18next": "^26.0.6",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-i18next": "^17.0.4",
		"react-router": "^7.1.1",
		"zustand": "^5.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@tauri-apps/api": "^2.2.0",
		"@tauri-apps/cli": "^2.2.3",
		"@types/react": "^18.3.14",
		"@types/react-dom": "^18.3.2",
		"@vitejs/plugin-react": "^4.7.0",
		"autoprefixer": "^10.4.20",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.7.2",
		"vite": "^6.0.5"
	}
}
